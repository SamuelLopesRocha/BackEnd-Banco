# Example environment variables
# Copy this file to .env and fill the values (do NOT commit your .env)

# MongoDB connection string examples:
# MongoDB Atlas SRV:
# MONGO_URI=mongodb+srv://usuario:senha@cluster0.mongodb.net/nome_db?retryWrites=true&w=majority

# Direct MongoDB URL:
# MONGO_URI=mongodb://usuario:senha@host:27017/nome_db

# Local fallback (only for testing if you run Mongo locally):
# MONGO_URI=mongodb://127.0.0.1:27017/banco_app
